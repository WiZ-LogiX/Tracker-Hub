# ============================================================
# PeleCanon — Environment Variables Example
# Copy to .env and fill in the real values.
# ============================================================

# --- Supabase (current auth + db) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# --- Neon (future provider) ---
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# --- Cloudflare R2 (file uploads) ---
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET=pelecanon-assets
# R2_PUBLIC_URL=https://your-custom-domain.com   # optional

# --- Notifications (n8n webhook for WhatsApp) ---
N8N_NOTIFY_WEBHOOK_URL=
N8N_WEBHOOK_TOKEN=

# --- App ---
SITE_URL=http://localhost:5173