# ---------------------------------------------------------------------------
# Cloudflare R2 configuration
# Public docs: docs/R2.md
#
# These can stay public; the placeholders below should not be replaced
# with real values. Real values live in your local .env (gitignored).
# ---------------------------------------------------------------------------
R2_ACCOUNT_ID="REPLACE_WITH_CLOUDFLARE_R2_ACCOUNT_ID"
R2_BUCKET="pelecanon"
R2_PUBLIC_URL="https://REPLACE_WITH_CLOUDFLARE_R2_ACCOUNT_ID.r2.cloudflarestorage.com/pelecanon"

# DO NOT PUT REAL SECRETS IN THIS FILE.
# Get a token from Cloudflare dashboard → R2 → Manage R2 API Tokens →
#   Create token, scope: Object Read & Write, bucket: pelecanon.
R2_ACCESS_KEY_ID="REPLACE_WITH_R2_ACCESS_KEY_ID"
R2_SECRET_ACCESS_KEY="REPLACE_WITH_R2_SECRET_ACCESS_KEY"

# ---------------------------------------------------------------------------
# n8n webhook integration (WhatsApp notifications via Evolution API)
#
# The full webhook URL for the n8n workflow that sends WhatsApp messages.
# Required for: sendNotification, sendTestNotification, sendTrackingWhatsapp.
N8N_NOTIFY_WEBHOOK_URL="https://n8n.wizlogix.qzz.io/webhook/order-stage-changed"

# Optional: shared secret token sent as X-Webhook-Token header for
# webhook authentication. Only needed if your n8n workflow validates it.
N8N_WEBHOOK_TOKEN=""

# Base URL for the customer-facing tracking link.
# Example: https://app.pelecanon.com — must NOT end with a slash.
# Falls back to a relative /track?ref=... path if unset.
SITE_URL="https://app.pelecanon.com"
