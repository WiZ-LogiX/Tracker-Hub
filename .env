# ---------------------------------------------------------------------------
# Cloudflare R2 configuration (apply to ALL deployments of this app)
# ---------------------------------------------------------------------------
# Public documents for set-up: docs/R2.md
#
# Required. The 32-hex Cloudflare account ID — find it at
# Cloudflare dashboard → R2 → right-hand "Account ID".
R2_ACCOUNT_ID="57643050bdeb9c487a223ccf7815bd94"

# Required. The bucket that holds production-photos, attachments, and avatars.
# Lowercase letters, digits, and hyphens only. Must already exist in R2.
R2_BUCKET="pelecanon"

# Required. Public URL the app uses when building direct (non-signed) URLs.
# Two supported forms:
#   1. Custom domain bound to the bucket (recommended):
#      https://files.your-domain.example
#   2. Default R2 URL (works only if the bucket has Public Access enabled):
#      https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com/<R2_BUCKET>
R2_PUBLIC_URL="https://57643050bdeb9c487a223ccf7815bd94.r2.cloudflarestorage.com/pelecanon"

# Required. API token credentials from R2 → Manage R2 API Tokens.
# ----------------------------------------------------------------
# FILL FROM CLOUDFLARE → paste locally in your editor. DO NOT
# commit, paste in chat, or share this file anywhere.
#                             ↓↓↓↓
R2_ACCESS_KEY_ID=""        # ← paste your R2 access key here
R2_SECRET_ACCESS_KEY=""    # ← paste your R2 secret here

# ---------------------------------------------------------------------------
# Cloudflare Workers / build configuration
# ---------------------------------------------------------------------------
# Vite build vs. Cloudflare plugin reads certain vars. Leave as-is unless
# you are doing local-only changes.